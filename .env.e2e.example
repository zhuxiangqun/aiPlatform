# E2E smoke env example (DO NOT put real secrets in git)
#
# Usage:
#   cp .env.e2e.example .env.e2e
#   # edit .env.e2e and fill your key
#   ./e2e_smoke.sh
#
# DeepSeek (OpenAI-compatible)
AIPLAT_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-REPLACE_ME

# Default agent model for e2e (推理模型)
# 你也可以用 AIPLAT_AGENT_MODEL=deepseek-chat
AIPLAT_AGENT_MODEL=deepseek-reasoner

# Optional overrides
# AIPLAT_LLM_BASE_URL=https://api.deepseek.com/v1
# AIPLAT_LLM_MODEL=deepseek-reasoner

